# LLM Paper Tracker 配置示例
# 复制此文件为 config.yaml 并填入实际值

paper:
  max_papers_per_day: 10
  days_back: 7

arxiv:
  categories:
    - cs.CL
    - cs.LG
    - cs.AI

llm:
  enabled: true
  api_key: "your-api-key-here"
  model: "qwen3.5-plus"
  timeout: 180

email:
  enabled: true
  smtp_host: "smtp.qq.com"
  smtp_port: 465
  smtp_user: "your-email@example.com"
  smtp_password: "your-auth-code"
  from_name: "LLM Paper Tracker"
  to_emails:
    - "recipient@example.com"

scheduler:
  time: "09:30"
  enabled: true

logging:
  level: INFO
  file: data/logs/tracker.log
